{
  "expo": {
    "name": "language-training",
    "slug": "language-training",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "languagetraining",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.johnnithin08.language-training",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Lingua AI uses speech recognition to convert your voice into text for conversation practice.",
        "NSMicrophoneUsageDescription": "Lingua AI uses the microphone so you can speak and practice conversations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.johnnithin08.languagetraining"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "react-native-voicekit",
        {
          "speechRecognitionPermission": "Allow Lingua AI to convert your speech to text.",
          "microphonePermission": "Allow Lingua AI to access your microphone."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-audio-api",
        {
          "iosMicrophonePermission": "Lingua AI uses the microphone for voice-to-voice practice.",
          "androidPermissions": [
            "android.permission.RECORD_AUDIO"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0a2e3ef-f190-4773-a232-fe6165997dc4"
      }
    }
  }
}
